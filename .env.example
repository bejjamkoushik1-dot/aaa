# RVRJC Library Management System Configuration

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Base URL for reset links (IMPORTANT: Change to your domain in production)
BASE_URL=http://localhost:3000

# Email Configuration for Password Reset (REQUIRED for forgot password to work)
# For Gmail, enable 2-factor authentication and create an App Password:
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Select "Mail" and "Other (Custom name)"
# 3. Enter "RVRJC Library" and generate password
# 4. Use that password below (NOT your regular Gmail password)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-generated-app-password
MAIL_FROM=RVRJC Library <your-email@gmail.com>

# Alternative email providers:
# Outlook: SMTP_HOST=smtp-mail.outlook.com, SMTP_PORT=587
# Yahoo: SMTP_HOST=smtp.mail.yahoo.com, SMTP_PORT=587

# Optional: Node environment
NODE_ENV=development

# Database (SQLite - no additional config needed)
DB_PATH=./data/library.db
